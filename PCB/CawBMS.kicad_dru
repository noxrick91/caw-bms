(version 1)
(rule "ic area"
   (constraint clearance (min 5.5mil))
   (condition "A.Type != 'zone' && A.insideArea('ic_zone')"))

(version 1)
(rule "ic csd13381f4"
   (constraint clearance (min 3mil))
   (condition "A.Type != 'zone' && A.insideArea('ic_csd13381f4')"))

(version 1)
(rule "ic lm66200drlr"
   (constraint clearance (min 3mil))
   (condition "A.Type != 'zone' && A.insideArea('ic_lm66200drlr')"))
